# ── API URL ───────────────────────────────────────────────────────────────────
# URL backend API yang akan dipanggil oleh frontend.
#
# Jika frontend & backend di-deploy bersama (docker-compose / Coolify),
# dan Nginx sudah reverse proxy /api → backend, cukup gunakan path relatif:
VITE_API_URL=/api
#
# Jika backend di domain/port terpisah, gunakan URL lengkap:
# VITE_API_URL=https://api.yourdomain.com/api
